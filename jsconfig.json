{
  "compilerOptions": {
    "checkJs": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "baseUrl": ".",
    "paths": {},
    "lib": [
      "ES2020"
    ],
    "target": "ES2020",
    "moduleResolution": "node",
    "typeRoots": [
      "./types"
    ]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}